# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=crm_supermercado
POSTGRES_USER=admin
POSTGRES_PASSWORD=supersecret
DATABASE_URL=postgresql://admin:supersecret@pgbouncer:6432/crm_supermercado
DATABASE_URL_REPLICA=postgresql://admin:supersecret@postgres-replica:5433/crm_supermercado
DATABASE_POOL_MIN=5
DATABASE_POOL_MAX=25
DATABASE_QUERY_LOG_SLOW=100

# PgBouncer
PGBOUNCER_PORT=6432
PGBOUNCER_POOL_MODE=transaction

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# RabbitMQ
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=admin

# JWT
JWT_SECRET=your-jwt-secret-key-change-in-production
JWT_EXPIRATION=3600

# API
API_PORT=3000
API_PREFIX=/api/v1

# Encryption
AES_256_KEY=your-aes-256-key-32-chars-minimum
MFA_SECRET=your-mfa-secret

# Email
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# AWS S3 (backup/files)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET=

# Monitoramento
GRAFANA_PORT=3001
PROMETHEUS_PORT=9090

# MinIO / S3
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_REGION=us-east-1
STORAGE_PROVIDER=minio

# SSL
SSL_CERT_PATH=/etc/nginx/ssl/cert.pem
SSL_KEY_PATH=/etc/nginx/ssl/key.pem
