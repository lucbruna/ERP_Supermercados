{
    "name":  "ai-service",
    "version":  "1.0.0",
    "description":  "Artificial Intelligence Microservice",
    "private":  true,
    "license":  "MIT",
    "scripts":  {
                    "build":  "nest build",
                    "start":  "nest start",
                    "start:dev":  "nest start --watch",
                    "start:prod":  "node dist/main",
                    "prisma:generate":  "prisma generate",
                    "prisma:migrate":  "prisma migrate dev",
                    "prisma:push":  "prisma db push",
                    "lint":  "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
                    "test":  "jest",
                    "test:watch":  "jest --watch",
                    "test:cov":  "jest --coverage"
                },
    "dependencies":  {
                         "@nestjs/common":  "^10.3.0",
                         "@nestjs/core":  "^10.3.0",
                         "@nestjs/platform-express":  "^10.3.0",
                         "@nestjs/swagger":  "^7.2.0",
                         "@prisma/client":  "^5.8.0",
                         "@tensorflow/tfjs":  "^4.17.0",
                         "axios":  "^1.6.5",
                         "class-transformer":  "^0.5.1",
                         "class-validator":  "^0.14.0",
                         "compromise":  "^14.10.0",
                         "csv-parse":  "^5.5.3",
                         "fast-csv":  "^5.0.1",
                         "natural":  "^6.11.1",
                         "openai":  "^4.28.0",
                         "reflect-metadata":  "^0.1.13",
                         "rxjs":  "^7.8.1",
                         "@crm/logging":  "file:../../shared/logging",
                         "@crm/tracing":  "file:../../shared/tracing"
                     },
    "devDependencies":  {
                            "@nestjs/cli":  "^10.3.0",
                            "@nestjs/schematics":  "^10.1.0",
                            "@types/express":  "^4.17.21",
                            "@types/node":  "^20.10.0",
                            "prisma":  "^5.8.0",
                            "typescript":  "^5.3.2",
                            "ts-loader":  "^9.5.1",
                            "tsconfig-paths":  "^4.2.0",
                            "jest":  "^29.7.0",
                            "source-map-support":  "^0.5.21",
                            "@types/jest":  "^29.5.11",
                            "ts-jest":  "^29.1.1",
                            "@nestjs/testing":  "^10.3.0"
                        },
    "jest":  {
                 "testEnvironment":  "node",
                  "transformIgnorePatterns":  [
                                                   "/node_modules/(?!uuid|@nestjs|@prisma|ts-lib|class-validator|class-transformer)/"
                                               ],
                 "rootDir":  "src",
                 "coverageDirectory":  "../coverage",
                 "collectCoverageFrom":  [
                                             "**/*.(t|j)s"
                                         ],
                 "moduleFileExtensions":  [
                                              "js",
                                              "json",
                                              "ts"
                                          ],
                 "testRegex":  ".*\\.spec\\.ts$",
                 "transform":  {
                                   "^.+\\.(t|j)s$":  ["ts-jest", { "isolatedModules": true }]
                               },
                 "moduleNameMapper":  {
                                          "^@crm/tracing$":  "<rootDir>/__mocks__/@crm/tracing.ts",
                                          "^@crm/tracing/(.*)$":  "<rootDir>/__mocks__/@crm/tracing.ts",
                                          "^@crm/logging$":  "<rootDir>/__mocks__/@crm/logging.ts",
                                          "^@crm/logging/(.*)$":  "<rootDir>/__mocks__/@crm/logging.ts"
                                      }
             }
}