{
    "name":  "@crm/realtime-service",
    "version":  "1.0.0",
    "description":  "ERP Supermercado - Real-Time WebSocket Microservice",
    "private":  true,
    "scripts":  {
                    "build":  "nest build",
                    "start":  "nest start",
                    "start:dev":  "nest start --watch",
                    "start:prod":  "node dist/main",
                    "lint":  "eslint \"{src,test}/**/*.ts\" --fix",
                    "format":  "prettier --write \"src/**/*.ts\"",
                    "test":  "jest",
                    "test:watch":  "jest --watch",
                    "test:cov":  "jest --coverage"
                },
    "dependencies":  {
                         "@nestjs/common":  "^10.3.0",
                         "@nestjs/core":  "^10.3.0",
                         "@nestjs/platform-socket.io":  "^10.3.0",
                         "@nestjs/websockets":  "^10.3.0",
                         "@nestjs/jwt":  "^10.2.0",
                         "@nestjs/config":  "^4.0.4",
                         "socket.io":  "^4.7.4",
                         "ioredis":  "^5.3.2",
                         "@socket.io/redis-adapter":  "^8.2.1",
                         "class-validator":  "^0.14.0",
                         "class-transformer":  "^0.5.1",
                         "reflect-metadata":  "^0.2.1",
                         "rxjs":  "^7.8.1",
                         "@crm/logging":  "file:../../shared/logging",
                         "@crm/tracing":  "file:../../shared/tracing"
                     },
    "devDependencies":  {
                            "@nestjs/cli":  "^10.3.0",
                            "@nestjs/schematics":  "^10.1.0",
                            "ts-node":  "^10.9.2",
                            "typescript":  "^5.3.3",
                            "ts-loader":  "^9.5.1",
                            "tsconfig-paths":  "^4.2.0",
                            "jest":  "^29.7.0",
                            "source-map-support":  "^0.5.21",
                            "@types/jest":  "^29.5.11",
                            "ts-jest":  "^29.1.1",
                            "@nestjs/testing":  "^10.3.0"
                        },
    "jest":  {
                 "testEnvironment":  "node",
                  "transformIgnorePatterns":  [
                                                   "/node_modules/(?!uuid|@nestjs|@prisma|ts-lib|class-validator|class-transformer)/"
                                               ],
                 "rootDir":  "src",
                 "coverageDirectory":  "../coverage",
                 "collectCoverageFrom":  [
                                             "**/*.(t|j)s"
                                         ],
                 "moduleFileExtensions":  [
                                              "js",
                                              "json",
                                              "ts"
                                          ],
                 "testRegex":  ".*\\.spec\\.ts$",
                 "transform":  {
                                   "^.+\\.(t|j)s$":  ["ts-jest", { "isolatedModules": true }]
                               },
                 "moduleNameMapper":  {
                                          "^@crm/tracing$":  "<rootDir>/__mocks__/@crm/tracing.ts",
                                          "^@crm/tracing/(.*)$":  "<rootDir>/__mocks__/@crm/tracing.ts",
                                          "^@crm/logging$":  "<rootDir>/__mocks__/@crm/logging.ts",
                                          "^@crm/logging/(.*)$":  "<rootDir>/__mocks__/@crm/logging.ts"
                                      }
             }
}