{
    "name":  "@erp-supermercado/integration-api",
    "version":  "1.0.0",
    "description":  "Integration API - E-commerce, Scale, Scanner for ERP Supermercado",
    "private":  true,
    "scripts":  {
                    "build":  "nest build",
                    "start":  "nest start",
                    "start:dev":  "nest start --watch",
                    "start:prod":  "node dist/main",
                    "prisma:generate":  "prisma generate",
                    "prisma:migrate":  "prisma migrate dev",
                    "test":  "jest",
                    "test:watch":  "jest --watch",
                    "test:cov":  "jest --coverage"
                },
    "dependencies":  {
                         "@nestjs/common":  "^10.3.0",
                         "@nestjs/core":  "^10.3.0",
                         "@nestjs/platform-express":  "^10.3.0",
                         "@nestjs/swagger":  "^7.2.0",
                         "@prisma/client":  "^5.8.0",
                         "class-transformer":  "^0.5.1",
                         "class-validator":  "^0.14.0",
                         "reflect-metadata":  "^0.1.14",
                         "rxjs":  "^7.8.1",
                          "@nestjs/axios":  "^3.0.2",
                          "axios":  "^1.6.5",
                          "@crm/logging":  "file:../../shared/logging"
                     },
    "devDependencies":  {
                            "@nestjs/cli":  "^10.3.0",
                            "@nestjs/testing":  "^10.3.0",
                            "@types/express":  "^4.17.21",
                            "@types/jest":  "^29.5.11",
                            "@types/node":  "^20.11.0",
                            "jest":  "^29.7.0",
                            "prisma":  "^5.8.0",
                            "source-map-support":  "^0.5.21",
                            "ts-jest":  "^29.1.1",
                            "ts-loader":  "^9.5.1",
                            "ts-node":  "^10.9.2",
                            "tsconfig-paths":  "^4.2.0",
                            "typescript":  "^5.3.3"
                        },
    "jest":  {
                 "testEnvironment":  "node",
                  "transformIgnorePatterns":  [
                                                   "/node_modules/(?!uuid|@nestjs|@prisma|ts-lib|class-validator|class-transformer)/"
                                               ],
                 "rootDir":  "src",
                 "coverageDirectory":  "../coverage",
                 "collectCoverageFrom":  [
                                             "**/*.(t|j)s"
                                         ],
                 "moduleFileExtensions":  [
                                              "js",
                                              "json",
                                              "ts"
                                          ],
                 "testRegex":  ".*\\.spec\\.ts$",
                 "transform":  {
                                   "^.+\\.(t|j)s$":  ["ts-jest", { "isolatedModules": true }]
                               },
                 "moduleNameMapper":  {
                                          "^@crm/logging/(.*)$":  "<rootDir>/__mocks__/@crm/logging.ts",
                                          "^@crm/logging$":  "<rootDir>/__mocks__/@crm/logging.ts"
                                      }
             }
}