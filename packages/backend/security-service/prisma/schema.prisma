generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AuditoriaSeguranca {
  id        String   @id @default(uuid()) @db.Uuid
  companyId String   @map("company_id") @db.Uuid
  usuarioId String   @map("usuario_id")
  acao      String
  recurso   String
  recursoId String?  @map("recurso_id")
  ip        String
  userAgent String   @map("user_agent")
  tipo      String   @default("ACESSO")
  gravidade String   @default("BAIXA")
  detalhes  String?
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("auditoria_seguranca")
}

model RegraSeguranca {
  id        String   @id @default(uuid()) @db.Uuid
  companyId String   @map("company_id") @db.Uuid
  nome      String
  tipo      String
  config    Json
  ativo     Boolean  @default(true)
  criadoPor String   @map("criado_por")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("regras_seguranca")
}

model TentativaAcesso {
  id        String   @id @default(uuid()) @db.Uuid
  email     String
  ip        String
  userAgent String   @map("user_agent")
  sucesso   Boolean
  motivo    String?
  data      DateTime @default(now())

  @@map("tentativas_acesso")
}

model BloqueioIP {
  id        String    @id @default(uuid()) @db.Uuid
  ip        String
  motivo    String
  criadoPor String    @map("criado_por")
  dataInicio DateTime @default(now()) @map("data_inicio")
  dataFim   DateTime? @map("data_fim")
  ativo     Boolean   @default(true)
  createdAt DateTime  @default(now()) @map("created_at")

  @@map("bloqueios_ip")
}

model LogCriptografia {
  id        String   @id @default(uuid()) @db.Uuid
  acao      String
  recurso   String
  usuarioId String   @map("usuario_id")
  data      DateTime @default(now())

  @@map("logs_criptografia")
}

model ConsentimentoLGPD {
  id              String    @id @default(uuid()) @db.Uuid
  usuarioId       String    @map("usuario_id")
  tipo            String
  concedido       Boolean
  dataConcessao   DateTime  @default(now()) @map("data_concessao")
  dataRevogacao   DateTime? @map("data_revogacao")
  ip              String
  userAgent       String    @map("user_agent")
  createdAt       DateTime  @default(now()) @map("created_at")

  @@map("consentimentos_lgpd")
}

model SolicitacaoTitular {
  id                String    @id @default(uuid()) @db.Uuid
  usuarioId         String    @map("usuario_id")
  tipo              String
  descricao         String
  dadosRelacionados String?   @map("dados_relacionados")
  status            String    @default("PENDENTE")
  resposta          String?
  prazoResposta     DateTime? @map("prazo_resposta")
  criadoEm          DateTime  @default(now()) @map("criado_em")
  concluidoEm       DateTime? @map("concluido_em")

  @@map("solicitacoes_titular")
}

model DadosPessoais {
  id         String   @id @default(uuid()) @db.Uuid
  usuarioId  String   @map("usuario_id")
  tipo       String
  hash       String
  finalidade String
  origem     String
  criadoEm   DateTime @default(now()) @map("criado_em")

  @@map("dados_pessoais")
}

model PoliticaPrivacidade {
  id                 String    @id @default(uuid()) @db.Uuid
  versao             String
  texto              String
  dataPublicacao     DateTime? @map("data_publicacao")
  dataInicioVigencia DateTime  @default(now()) @map("data_inicio_vigencia")
  ativo              Boolean   @default(true)
  criadoEm           DateTime  @default(now()) @map("criado_em")

  @@map("politicas_privacidade")
}

model AceitePolitica {
  id         String   @id @default(uuid()) @db.Uuid
  usuarioId  String   @map("usuario_id")
  politicaId String   @map("politica_id") @db.Uuid
  aceito     Boolean
  dataAceite DateTime @default(now()) @map("data_aceite")
  ip         String
  criadoEm   DateTime @default(now()) @map("criado_em")

  @@map("aceites_politica")
}
