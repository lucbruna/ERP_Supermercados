{
  "name": "crm-supermercado",
  "version": "1.0.0",
  "private": true,
  "description": "ERP/CRM Corporativo para Supermercados, Atacados e Varejo",
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "echo 'Run each service individually: cd packages/backend/<service> && npm run dev'",
    "dev:frontend": "echo 'Run each service individually: cd packages/frontend/<app> && npm run dev'",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:build": "docker-compose build"
  },
  "workspaces": [
    "packages/shared/logging"
  ],
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "concurrently": "^8.2.2",
    "eslint": "^8.56.0",
    "prettier": "^3.2.4",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.22",
    "@opentelemetry/api": "^1.9.1",
    "@types/express": "^4.17.25",
    "@types/uuid": "^9.0.8",
    "express": "^4.22.2",
    "rxjs": "^7.8.2",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^4.7.1",
    "winston-elasticsearch": "^0.17.4",
    "winston-transport": "^4.9.0"
  }
}
